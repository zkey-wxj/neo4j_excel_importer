# 复制为 .env 并填写后运行 python -m main 启动远程调试
INSTALL_METHOD=remote
REMOTE_INSTALL_URL=https://your-dify-instance/api/v1/plugins/install/remote
REMOTE_INSTALL_KEY=your-debug-key-here

# Neo4j 导入脚本配置（temp/import_graph_to_neo4j.py）
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
GRAPH_DATA_DIR=temp/data
GRAPH_GROUP_ID=YUWEN
GRAPH_BATCH_SIZE=500
GRAPH_CLEAR_BEFORE_IMPORT=false
GRAPH_PAYLOAD_OUTPUT=temp/merged_graph_payload.json
GRAPH_DEDUP_OUTPUT=temp/dedup_report.json
